  "keyFeatures": [
    "Ultra-fast agent spawning (<1s boot time)",
    "Minimal resource footprint (<10MB RAM per agent)",
    "Docker-isolated workspace environments",
    "Multi-channel gateway (Telegram, Discord, Slack, Line, QQ)",
    "Extensible tool system with filesystem, shell, web, and hardware tools",
    "Dynamic skills loading from GitHub repositories",
    "Scheduled task execution with cron-style jobs",
    "OAuth authentication for OpenAI and token-based auth",
    "Subagent spawning for parallel task execution",
    "Device event monitoring and heartbeat service",
    "REST API and health check endpoints",
    "Support for multiple LLM providers (Gemini, OpenAI, Anthropic, Claude, local vLLM)"
  ],
  "publicApiSurface": [
    "weaver onboard - Initialize configuration and workspace",
    "weaver agent - Interactive or direct agent execution",
    "weaver gateway - Start multi-channel gateway server",
    "weaver auth login - OAuth and token authentication",
    "weaver cron - Manage scheduled tasks",
    "weaver skills - Install, list, and manage skills",
    "weaver migrate - Migrate from OpenClaw",
    "POST /chat - REST API for chat interactions",
    "GET /health - Health check endpoint",
    "GET /ready - Readiness probe endpoint",
    "Tool: read_file - Read file contents",
    "Tool: write_file - Write or create files",
    "Tool: edit_file - Edit existing files",
    "Tool: exec - Execute shell commands",
    "Tool: web_search - Search the web (Brave/DuckDuckGo)",
    "Tool: web_fetch - Fetch web page content",
    "Tool: spawn_subagent - Create parallel subagent",
    "Tool: cron - Manage scheduled tasks",
    "Tool: message - Send messages to channels",
    "Tool: i2c - Hardware I2C communication",
    "Tool: spi - Hardware SPI communication"
  ]
}
